<UserControl x:Class="DiscRipper.Controls.SubmitButtons"
             x:ClassModifier="internal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:DiscRipper.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <ui:Button x:Name="GuidedViewButton" Margin="10" VerticalAlignment="Stretch" Visibility="{Binding GuidedViewVisible, RelativeSource={RelativeSource AncestorType=local:SubmitButtons}, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Switch to guided view" FontSize="24" Margin="20,10,20,10" />
        </ui:Button>
        <ui:Button x:Name="CancelButton" Margin="10" VerticalAlignment="Stretch">
            <TextBlock Text="Cancel" FontSize="32" Margin="20,10,20,10" />
        </ui:Button>
        <ui:Button x:Name="SubmitButton" Appearance="Primary" Margin="10" VerticalAlignment="Stretch">
            <TextBlock Text="Submit!" FontSize="48" Margin="20,10,20,10" />
        </ui:Button>
    </StackPanel>
</UserControl>
