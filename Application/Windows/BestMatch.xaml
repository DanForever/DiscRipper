<windows:ThemedWindow x:Class="DiscRipper.Windows.BestMatch"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:DiscRipper"
        xmlns:windows="clr-namespace:DiscRipper.Windows.Base"
        xmlns:localWindows="clr-namespace:DiscRipper.Windows"
        mc:Ignorable="d"
        Title="Your disc best matches these search results" Height="800" Width="1000">
    <DockPanel>
        <ui:TitleBar DockPanel.Dock="Top" Title="{Binding Title, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}" FontWeight="SemiBold" />
        
        <Button x:Name="Previous" DockPanel.Dock="Left" Click="Previous_Click" VerticalAlignment="Stretch">
            <TextBlock Text="&#x2190;" FontSize="48" />
        </Button>
        <Button x:Name="Next" DockPanel.Dock="Right" Click="Next_Click" VerticalAlignment="Stretch">
            <TextBlock Text="&#x2192;" FontSize="48" />
        </Button>
        <Grid DockPanel.Dock="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="60" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Column="0" Grid.Row="0" Text="Title" Grid.RowSpan="2" Padding="10,5,10,5" Background="DodgerBlue" FontWeight="DemiBold" FontSize="24" />
            <TextBlock Grid.Column="0" Grid.Row="1" Text="Disc Index" Padding="10,5,10,5" Background="#ff7ec0d7" FontWeight="DemiBold" FontSize="24" />
            <TextBlock Grid.Column="1" Grid.Row="0" Text="{Binding tddbRelease.Title }" Padding="10,5,10,5" Background="DodgerBlue" FontSize="24" />
            <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding tddbDisc.Index }" Padding="10,5,10,5" Background="#ff7ec0d7" FontSize="24" />
        </Grid>
        <DockPanel DockPanel.Dock="Bottom">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" MinWidth="343">
                <ui:Button Click="Cancel_Click" Margin="10" VerticalAlignment="Stretch">
                    <TextBlock Text="Cancel" FontSize="32" Margin="20,10,20,10" />
                </ui:Button>
                <ui:Button Click="Rip_Click" Appearance="Primary" Margin="10" VerticalAlignment="Stretch" IsEnabled="{Binding Drive, TargetNullValue=False, RelativeSource={RelativeSource AncestorType=localWindows:BestMatch}}">
                    <TextBlock Text="Rip!" FontSize="48" Margin="20,10,20,10" />
                </ui:Button>
            </StackPanel>
            <ui:Button DockPanel.Dock="Left" Click="AddNewRelease_Click" Margin="10" VerticalAlignment="Stretch">
                <TextBlock Text="Add new release" FontSize="32" Margin="20,10,20,10" />
            </ui:Button>
            <ui:Button DockPanel.Dock="Left" Click="AddDiscToRelease_Click" Margin="10" VerticalAlignment="Stretch">
                <TextBlock Text="Add disc to release" FontSize="32" Margin="20,10,20,10" />
            </ui:Button>
        </DockPanel>
        <Image x:Name="CoverImage" Stretch="Uniform" DockPanel.Dock="Right" />
        <DockPanel DockPanel.Dock="Bottom">
            <Button DockPanel.Dock="Right" Click="PickFolder_Click">
                <TextBlock Text="Pick folder" Margin="5" />
            </Button>
            <TextBox x:Name="OutputPath" />
        </DockPanel>
        <DockPanel DockPanel.Dock="Top">
            <DataGrid x:Name="FoundTitles" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Rip" Binding="{Binding Rip}" />
                    <DataGridTextColumn Header="Title" Binding="{Binding Title}" IsReadOnly="True" Width="*" />
                    <DataGridTextColumn Header="Duration" Binding="{Binding Duration}" IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </DockPanel>
</windows:ThemedWindow>
